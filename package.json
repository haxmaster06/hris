{
  "name": "hris-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Universal HRIS Platform (Nexus HR) Monorepo",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "web:dev": "npm run dev -w apps/web",
    "web:build": "npm run build -w apps/web",
    "web:start": "npm run start -w apps/web",
    "web:lint": "npm run lint -w apps/web"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
