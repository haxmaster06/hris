# =============================================
# Universal HRIS Platform - .gitignore
# =============================================

# === OS Generated ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# === IDE / Editor ===
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.code-workspace
.agent/

# === Environment Files ===
.env
.env.local
.env.*.local
.env.production
.env.staging

# === Node.js / Frontend ===
node_modules/
.next/
out/
dist/
build/
.turbo/
.vercel/
.cache/
*.tsbuildinfo
next-env.d.ts

# === PHP / Laravel Backend ===
vendor/
storage/*.key
storage/app/*
!storage/app/.gitkeep
storage/framework/cache/data/*
!storage/framework/cache/data/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
bootstrap/cache/*
!bootstrap/cache/.gitkeep
.phpunit.result.cache
.phpunit.cache
phpunit.xml
Homestead.json
Homestead.yaml
auth.json
*.phar

# === Composer ===
composer.phar

# === Docker ===
docker-compose.override.yml

# === Testing ===
coverage/
.nyc_output/
*.lcov
.coverage

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Build Artifacts ===
*.map

# === Package Managers (Tracked for consistency) ===
# !package-lock.json
# !yarn.lock
# !pnpm-lock.yaml
# !composer.lock

# === Secrets (NEVER commit) ===
*.pem
*.key
*.cert
*.p12
